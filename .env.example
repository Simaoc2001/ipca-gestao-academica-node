# Configurações do Servidor
PORT=3001
NODE_ENV=development

# MongoDB - Adiciona a tua URI aqui (vazio para usar dados em memória)
# Exemplo: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGODB_URI=

# Sessão
SESSION_SECRET=sua_chave_secreta_muito_segura_aqui_123!@#

# MySQL (para migração de dados - opcional)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ipca
