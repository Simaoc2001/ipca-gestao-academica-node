# Configurações do Servidor
PORT=3001
NODE_ENV=development

# MongoDB - Adiciona a tua URI aqui
# ⚠️ IMPORTANTE: Inclui "/ipca_academica" no final da URI para usar a base de dados correta!
# Exemplo (Cloud): mongodb+srv://username:password@cluster.mongodb.net/ipca_academica?retryWrites=true&w=majority
# Exemplo (Local):  mongodb://localhost:27017/ipca_academica
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/ipca_academica?retryWrites=true&w=majority

# Sessão
SESSION_SECRET=sua_chave_secreta_muito_segura_aqui_123!@#

# MySQL (para migração de dados - opcional)
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=ipca
